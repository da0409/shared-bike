/*
 * ============================================
 * 个人中心页样式
 * ============================================
 * 设计风格：
 * - 顶部：橙色渐变（和主题色一致）
 * - 底部：白色菜单列表
 * ============================================
 */

/* ---------- 页面容器 ---------- */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background: #f5f5f5;        /* 浅灰色背景 */
}

/* ---------- 头部区域（橙色渐变背景） ---------- */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #ff6600, #ff8c00);  /* 橙色渐变 */
  width: 100%;
  padding: 60rpx 0;
  box-sizing: border-box;
}

/* 头像容器 - 圆形裁剪 */
.avatar-box {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;                   /* 圆形 */
  overflow: hidden;                      /* 超出部分隐藏 */
  border: 6rpx solid rgba(255,255,255,0.5);  /* 半透明白色边框 */
  margin-bottom: 20rpx;
}

.avatar {
  width: 100%;
  height: 100%;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.phone {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* ---------- 菜单列表 ---------- */
.menu-list {
  width: 100%;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

/* 单个菜单项 - 白色卡片风格 */
.menu-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);  /* 极浅阴影 */
}

.menu-item:active {
  background: #f9f9f9;          /* 点击反馈 */
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;                      /* 文字占满剩余空间 */
  font-size: 30rpx;
  color: #333;
}

/* 右箭头符号 */
.menu-arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* ---------- 底部 ---------- */
.footer {
  width: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
  margin-top: 40rpx;
  text-align: center;
}

/* 退出登录按钮 - 红色边框 */
.logout-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 32rpx;
  background: #fff;
  color: #e64340;               /* 红色文字 */
  border: 2rpx solid #e64340;   /* 红色边框 */
  margin-bottom: 20rpx;
}

.logout-btn:active {
  background: #fff5f5;
}

.version {
  font-size: 24rpx;
  color: #ccc;
}