/*
 * ============================================
 * 行程中页面样式
 * ============================================
 * 设计风格：绿蓝渐变背景（代表"绿色出行"）
 * ============================================
 */

/* ---------- 页面容器 ---------- */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 30rpx;
  min-height: 100vh;
  
  /* 绿蓝渐变（从绿色到青色） */
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

/* ---------- 头部 ---------- */
.trip-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.bike-emoji {
  font-size: 100rpx;        /* 大大的单车emoji */
  margin-bottom: 20rpx;
}

.trip-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.bike-label {
  font-size: 28rpx;
  color: #666;
}

/* ---------- 计时器 ---------- */
.timer-box {
  background: rgba(255,255,255,0.9);  /* 半透明白色背景 */
  border-radius: 30rpx;
  padding: 60rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.timer {
  font-size: 80rpx;                       /* 大号计时数字 */
  font-weight: bold;
  color: #333;
  font-family: 'Courier New', monospace;  /* 等宽字体，数字变化时不会抖动 */
  margin-bottom: 10rpx;
}

.timer-label {
  font-size: 26rpx;
  color: #999;
}

/* 
 * ---------- 信息网格（两列） ----------
 * 使用 flex 的 justify-content: space-between
 * 让两个卡片分别靠左和靠右排列
 */
.info-grid {
  display: flex;
  justify-content: space-between;
  width: 100%;
  margin-bottom: 60rpx;
}

.info-item {
  background: rgba(255,255,255,0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  flex: 1;                    /* 两个卡片等宽 */
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

/* 第一个卡片右边留间距 */
.info-item:first-child {
  margin-right: 20rpx;
}

.info-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6600;             /* 橙色数字，突出显示 */
  margin-bottom: 10rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
}

/* 
 * ---------- 底部按钮 ---------- 
 * position: fixed 固定在底部
 * 用 padding 让内容不贴边
 */
.btn-group {
  width: 100%;
  position: fixed;
  bottom: 60rpx;
  left: 0;
  right: 0;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 45rpx;
  font-size: 34rpx;
  text-align: center;
  border: none;
}

/* 结束行程按钮 - 红色警示色 */
.btn-end {
  background: #e64340;        /* 微信红 */
  color: #fff;
}

.btn-end:active {
  opacity: 0.8;
}